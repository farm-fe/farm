{
  "name": "@farmfe/ssr",
  "version": "0.0.0",
  "description": "SSR toolkit helpers for Farm",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@farmfe/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  }
}
