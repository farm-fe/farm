{
  "name": "@farmfe/js-plugin-vuetify",
  "version": "0.0.1",
  "description": "Farm plugin for Vuetify",
  "main": "./build/cjs/index.cjs",
  "types": "./build/esm/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "default": "./build/esm/index.mjs",
      "require": "./build/cjs/index.cjs",
      "import": "./build/esm/index.mjs",
      "types": "./build/esm/index.d.ts"
    }
  },
  "scripts": {
    "build:cjs": "cross-env FARM_FORMAT=cjs farm build",
    "build": "farm build && npm run build:cjs",
    "dev": "farm watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vuetify",
    "farm",
    "farmfe",
    "auto-import"
  ],
  "author": {
    "name": "\u82cf\u5411\u591c",
    "email": "fu050409@163.com",
    "url": "https://github.com/fu050409"
  },
  "license": "MIT",
  "devDependencies": {
    "@farmfe/cli": "workspace:*",
    "@farmfe/core": "workspace:*",
    "@farmfe/js-plugin-dts": "workspace:*",
    "@types/node": "^18.19.67",
    "cross-env": "^7.0.3"
  },
  "files": [
    "build",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "@vuetify/loader-shared": "^2.1.0",
    "upath": "^2.0.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farm-fe/farm.git"
  },
  "homepage": "https://github.com/farm-fe/farm",
  "bugs": {
    "url": "https://github.com/farm-fe/farm/issues"
  }
}
